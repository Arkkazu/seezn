$(".ft_navi .title").click(function () {
  var w =
    window.innerWidth ||
    document.documentElement.clientWidth ||
    document.body.clientWidth;
  var x = 768;
  if (w <= x) {
    $(this).toggleClass("open");
    $(this).next(".list").slideToggle();
  }
});

$(window).on("load resize", function () {
  var w =
    window.innerWidth ||
    document.documentElement.clientWidth ||
    document.body.clientWidth;
  var x = 768;

  if (w <= x) {
    $(".ft_navi .list").css("display", "none");
  } else {
    $(".ft_navi .list").css("display", "block");
  }
});

$("#contry02").click(function () {
  $(this).addClass("open");
  $("#other_contry").slideDown();
});
$("#contry01").click(function () {
  $(this).removeClass("open");
  $("#other_contry").slideUp();
});

$(".cat_box dl dd >span").click(function () {
  $(this).toggleClass("open");
  $(this).next("ul").slideToggle();
});

$(".member_menu .acc_btn").click(function () {
  $(this).toggleClass("open");
  $(this).next("div").slideToggle();
});

